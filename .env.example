# ═══════════════════════════════════════════════════════════════
# QueryX - Distributed Document Search Service
# Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://queryx:queryx_secret@localhost:5432/queryx_db?schema=public
POSTGRES_USER=queryx
POSTGRES_PASSWORD=queryx_secret
POSTGRES_DB=queryx_db

# ─────────────────────────────────────────────
# Elasticsearch
# ─────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=queryx_elastic_secret

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password  # Uncomment for production

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000       # 1 minute in milliseconds
RATE_LIMIT_MAX_REQUESTS=100      # Default max requests per window

# ─────────────────────────────────────────────
# Cache TTLs (seconds)
# ─────────────────────────────────────────────
CACHE_SEARCH_TTL=60
CACHE_DOCUMENT_TTL=300
CACHE_HEALTH_TTL=10

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=debug      # trace | debug | info | warn | error | fatal

# ─────────────────────────────────────────────
# Blue-Green Deployment (optional)
# ─────────────────────────────────────────────
DEPLOYMENT_COLOR=blue   # blue | green

# ─────────────────────────────────────────────
# Production (additional vars for docker-compose.prod.yml)
# ─────────────────────────────────────────────
# REDIS_PASSWORD=your_secure_redis_password
